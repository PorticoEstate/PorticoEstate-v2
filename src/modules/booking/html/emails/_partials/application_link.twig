{# CTA button link to application #}
<table cellpadding="0" cellspacing="0" role="presentation" style="margin: 16px 0 8px;">
<tr>
<td style="background-color: #793C8A; border-radius: 4px;">
    <a href="{{ link }}" style="display: inline-block; padding: 10px 24px; font-size: 14px; font-weight: 600; color: #ffffff; text-decoration: none; font-family: 'Inter', Arial, Helvetica, sans-serif;">{{ lang('booking.view_application')|default('Se søknad') }} #{{ application_id }}</a>
</td>
</tr>
</table>
