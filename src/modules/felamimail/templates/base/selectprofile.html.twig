{# Selectprofile template #}
{% block main %}
<center>

<form action="{{ action_url | raw }}" name="mailsettings" method="post">

<table width="90%" border="0" cellspacing="0" cellpading="1">
<tr class="th"> 
	<th width="40%" align="left" class="td_left">
		{{ lang('site_configuration') }}
	</th>
	<th width="60%" align="right" class="td_right">
		&nbsp;
	</th>
</tr>
<tr>
	<td width="40%" class="td_left">
		{{ lang('select_email_profile') }}:
	</td>
	<td width="60%" class="td_right">
		<select name="profileID">
			<option value="-1"></option>
			{{ select_options|raw }}
		</select>
		{{ lang('go_emailadmin') }}
	</td>
</tr>
</table>
<br><br>
<table width="90%" border="0" cellspacing="0" cellpading="1">
	<tr>
		<td width="90%" align="left"  class="td_left">
			<a href="{{ back_url }}">{{ lang('back') }}</a>
		</td>
		<td width="10%" align="center" class="td_right">
			<a href="javascript:document.mailsettings.submit();">{{ lang('save') }}</a>
		</td>
	</tr>
</table>

</form>
<br>
</center>
{% endblock %}

{% block select_option %}
			<option value="{{ profileID }}" {{ selected|raw }}>{{ description }}</option>
{% endblock %}
