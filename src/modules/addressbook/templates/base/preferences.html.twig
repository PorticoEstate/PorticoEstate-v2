{# Preferences template #}
{{ admin_tabs }}
<span style="font-weight: bold;font-family:{{ font }};">{{ lang('abprefs') }}</span><br />
<hr style="width: 100%; height: 2px;">
<br />
<br />
<table cellpadding="2" cellspacing="2" border="0" style="text-align: left;">
  <tbody>
  	<tr>
	<td style="vertical-align: middle;background:{{ th_bg }};horizontal-align:middle;"><span style="font-family:{{ font }};">{{ lang('select_cols') }} </span></td>
	</tr>
	
	<tr>
	{{ tabs }}
	</tr>

    <tr>
       <td style="vertical-align: top;">
      <form name="{{ select_columns_form_name|raw }}"
 action="{{ select_columns_form_action|raw }}" method="post">
 	<table>

	<tr>
	<td>
	{{ hider_open }}
        <select name="{{ select_columns_selectbox_name|raw }}" multiple size="5">
		{% block B_select_columns_form_options %}
		<option value="{{ value|raw }}">{{ lang('contact_field') }}</option>
		{% endblock %}
        </select>
	</td>
	<td>
        <select name="{{ select_columns_comtypes_name|raw }}" multiple size="5">
		{% block B_select_ctypes_options %}
		<option value="{{ commtype_description }}">{{ lang('comtype_field') }}</option>
		{% endblock %}
        </select>
	</td>
	</tr>
	<tr>
	<td>
	<center><input type='submit' value='{{ select_columns_submit_value|raw }}' name='select_fields'></center>
	{{ hider_close }}
	</td>
	</tr>
	</table>
	<tr><td><hr /></td></tr>
	<tr>
	<td>
	<table style="vertical-align: middle;horizontal-align:left">
	<tr>
		<td style="background:{{ th_bg }};">
		<span style="font-family:{{ font }};"> {{ lang('Select your default category') }} </span>
		</td>
	</tr>

	<tr>
		<td style="vertical-align:middle;"> 
		<select name='cat_id'>
			{{ cat_options|raw }}
		</select>
		</td>
	</tr>
	</td>
	</tr>
</table>
      </td>

    </tr>

  </tbody>
</table>
<br />

<table cellpadding="2" cellspacing="2" border="0"
 style="text-align: left; width: 100%;">
  <tbody>
    <tr style="background:{{ th_bg }};">
	{{ B_selected_rows|raw }} 
    </tr>
<tr>
<td colspan='100'>
<hr />
</td>
</tr>
<tr>
<td colspan='100'>
<input type='submit' value='{{ submit_save_value|raw }}' name='save'>
<input type='submit' value='{{ submit_cancel_value|raw }}' name='cancel'>
</td>
</tr>
  </tbody>
</table>
</form>

