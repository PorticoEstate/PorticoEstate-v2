<script>{{ source('@views/hospitality/show/hospitality_show.js') }}</script>
<script>
(function initHospCollab() {
	var hook = window.__hospWs;
	if (!hook) return;

	var root = hook.root;
	var accountId = root.dataset.accountId;
	var accountName = root.dataset.accountName;
	if (!accountId) return;

	var collab = new CollabClient({
		entityType: 'hospitality',
		entityId: root.dataset.hospitalityId,
		userName: accountName,
		userId: accountId
	});

	// Wire callbacks
	collab.onPresenceChange(function (peers) {
		hook.renderPresence(peers);
	});

	collab.onEditIndicator(function (info) {
		if (info.editing) {
			hook.showEditIndicator(info.peerId, info.userName, info.scope);
		} else {
			hook.removeEditIndicator(info.peerId, info.scope);
		}
	});

	collab.onEntityUpdate(function (update) {
		if (update.section === '_deleted') {
			hook.showDeletedBanner();
			return;
		}
		// Always refresh — server broadcasts arrive for all tabs including
		// the one that triggered the save. The saving tab already has fresh
		// data from its PUT response, so a redundant fetch is harmless.
		hook.refreshSection(update.section);
	});

	collab.onConnectionChange(function (connected) {
		hook.showConnectionStatus(connected);
	});

	// Expose for inline editing integration
	hook.collab = collab;
	collab.connect();
})();
</script>
{% if can_write %}
<script type="module">
import { DragDropManager, Droppable } from '@dnd-kit/dom';
import { Sortable, isSortable, SortableKeyboardPlugin, OptimisticSortingPlugin } from '@dnd-kit/dom/sortable';

(function initHospDnd() {
	var hook = window.__hospDnd;
	if (!hook) return;

	var manager = new DragDropManager();
	var sortables = [];
	var droppables = [];

	function destroyAll() {
		sortables.forEach(function (s) { s.destroy(); });
		sortables = [];
		droppables.forEach(function (d) { d.destroy(); });
		droppables = [];
	}

	function initSortables() {
		destroyAll();

		var root = hook.root;
		if (!root) return;

		// --- Group sortables ---
		var groupEls = root.querySelectorAll('[data-group-id][data-group-index]');
		groupEls.forEach(function (el) {
			var groupId = el.dataset.groupId;
			var index = parseInt(el.dataset.groupIndex, 10);
			var handle = el.querySelector('[data-drag-handle-group="' + groupId + '"]');

			var s = new Sortable(
				{
					id: 'group-' + groupId,
					index: index,
					group: 'groups',
					type: 'group',
					accept: 'group',
					element: el,
					handle: handle || undefined,
					feedback: 'default',
					plugins: [SortableKeyboardPlugin],
					data: { type: 'group', groupId: groupId }
				},
				manager
			);
			sortables.push(s);
		});

		// --- Article sortables + group container droppables ---
		var articleLists = root.querySelectorAll('[data-dnd-article-list]');
		articleLists.forEach(function (listEl) {
			var listGroupId = listEl.dataset.dndArticleList;

			// Create a Droppable for each container (groups + ungrouped)
			var d = new Droppable(
				{
					id: 'container-' + listGroupId,
					element: listEl,
					collisionPriority: 0, // Lowest — Sortable items take precedence
					accept: function (draggable) {
						return draggable.data && draggable.data.type === 'article';
					},
					data: { type: 'article-container', groupId: listGroupId }
				},
				manager
			);
			droppables.push(d);

			var articleEls = listEl.querySelectorAll('[data-article-id]');
			articleEls.forEach(function (el) {
				var articleId = el.dataset.articleId;
				var index = parseInt(el.dataset.articleIndex, 10);
				var handle = el.querySelector('[data-drag-handle-article="' + articleId + '"]');

				var s = new Sortable(
					{
						id: 'article-' + articleId,
						index: index,
						group: 'articles-' + listGroupId,
						type: 'article',
						accept: 'article',
						element: el,
						handle: handle || undefined,
						feedback: 'default',
						plugins: [SortableKeyboardPlugin, OptimisticSortingPlugin],
						data: { type: 'article', articleId: articleId, groupId: listGroupId }
					},
					manager
				);
				sortables.push(s);
			});
		});
	}

	// Collab: notify peers about drag start
	manager.monitor.addEventListener('dragstart', function () {
		if (window.__hospWs && window.__hospWs.collab) {
			window.__hospWs.collab.startEditing('drag:articles');
		}
	});

	// Visual feedback: highlight drop containers during drag
	manager.monitor.addEventListener('dragover', function (event) {
		var target = event.operation.target;
		// Remove all active highlights
		document.querySelectorAll('.hosp-show__drop-active').forEach(function (el) {
			el.classList.remove('hosp-show__drop-active');
		});
		// Highlight container if target is a container droppable
		if (target && target.data && target.data.type === 'article-container') {
			if (target.element) target.element.classList.add('hosp-show__drop-active');
		}
	});

	// Listen for dragend events
	manager.monitor.addEventListener('dragend', function (event) {
		// Collab: notify peers about drag end
		if (window.__hospWs && window.__hospWs.collab) {
			window.__hospWs.collab.stopEditing('drag:articles');
		}

		// Clean up highlights
		document.querySelectorAll('.hosp-show__drop-active').forEach(function (el) {
			el.classList.remove('hosp-show__drop-active');
		});

		var source = event.operation.source;
		var target = event.operation.target;
		if (!source) return;

		// Case 1: Sortable-to-sortable (within/between groups with items)
		if (isSortable(source)) {
			var sortable = source.sortable;
			var data = sortable.draggable.data;

			if (data.type === 'group') {
				handleGroupReorder(sortable, target);
				return;
			}

			if (data.type === 'article') {
				// Check if dropped on an empty container (Droppable, not Sortable)
				// Only handle as container drop if the target group differs from the source group
				if (target && target.data && target.data.type === 'article-container'
					&& String(target.data.groupId) !== String(data.groupId)) {
					handleArticleDropOnContainer(data.articleId, target.data.groupId);
				} else {
					// Normal sortable reorder (same or cross-group with items)
					handleArticleReorder(sortable, target);
				}
				return;
			}
		}
	});

	function handleGroupReorder(sourceSortable, target) {
		if (!target || !isSortable(target)) return;

		var sourceIdx = sourceSortable.initialIndex;
		var targetIdx = target.sortable.index;
		if (sourceIdx === targetIdx) return;

		// Build current group ID order from sortables
		var groupSortables = sortables
			.filter(function (s) { return s.draggable.data.type === 'group'; })
			.sort(function (a, b) { return a.index - b.index; });

		var ids = groupSortables.map(function (s) { return s.draggable.data.groupId; });

		// Move source from its position to target position
		var movedId = ids.splice(sourceIdx, 1)[0];
		ids.splice(targetIdx, 0, movedId);

		var data = hook.getData();
		var groups = data.article_groups || [];
		var promises = [];
		var apiUrl = hook.getApiUrl();

		ids.forEach(function (groupId, newIndex) {
			var original = groups.find(function (g) { return String(g.id) === String(groupId); });
			if (original && original.sort_order !== newIndex) {
				promises.push(hook.putJson(apiUrl + '/article-groups/' + groupId, { sort_order: newIndex }));
			}
		});

		if (promises.length > 0) {
			Promise.all(promises).then(function () {
				hook.showToast(hook.lang('saved'));
				hook.refreshData();
			}).catch(function (err) {
				hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
				hook.refreshData();
			});
		}
	}

	function handleArticleDropOnContainer(articleId, targetGroupId) {
		var apiUrl = hook.getApiUrl();
		var newGroupId = targetGroupId === 'ungrouped' ? null : parseInt(targetGroupId, 10);

		var payload = {
			article_group_id: newGroupId,
			sort_order: 0
		};

		hook.putJson(apiUrl + '/articles/' + articleId, payload).then(function () {
			hook.showToast(hook.lang('saved'));
			hook.refreshData();
		}).catch(function (err) {
			hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
			hook.refreshData();
		});
	}

	function handleArticleReorder(sourceSortable, target) {
		if (!target || !isSortable(target)) return;

		var articleId = sourceSortable.draggable.data.articleId;
		var sourceGroupId = sourceSortable.draggable.data.groupId;
		var targetGroupId = target.sortable.draggable.data.groupId;
		var apiUrl = hook.getApiUrl();

		function parseGroupId(gid) {
			if (!gid || gid === 'ungrouped') return null;
			return parseInt(gid, 10);
		}

		var sourceGid = parseGroupId(sourceGroupId);
		var targetGid = parseGroupId(targetGroupId);
		var groupChanged = sourceGid !== targetGid;

		var data = hook.getData();
		var allArticles = data.articles || [];
		var items = [];

		// Read the current DOM order — dnd-kit's optimistic sorting already
		// moved the elements, so the DOM reflects the user's intended order.
		var root = hook.root;

		if (!groupChanged) {
			// Same group: read DOM order from the article list container
			var listEl = root.querySelector('[data-dnd-article-list="' + sourceGroupId + '"]');
			if (!listEl) return;

			var domIds = Array.from(listEl.querySelectorAll('[data-article-id]'))
				.map(function (el) { return el.dataset.articleId; });

			// Check if DOM order differs from data order
			var dataIds = allArticles
				.filter(function (a) {
					return String(a.article_group_id || '') === String(sourceGid || '');
				})
				.sort(function (a, b) { return (a.sort_order || 0) - (b.sort_order || 0); })
				.map(function (a) { return String(a.id); });

			var changed = domIds.length !== dataIds.length || domIds.some(function (id, i) { return id !== dataIds[i]; });
			if (!changed) return;

			domIds.forEach(function (aid, i) {
				items.push({ id: parseInt(aid, 10), sort_order: i, article_group_id: sourceGid });
			});
		} else {
			// Cross-group: read DOM order for both affected containers
			var sourceListEl = root.querySelector('[data-dnd-article-list="' + sourceGroupId + '"]');
			var targetListEl = root.querySelector('[data-dnd-article-list="' + targetGroupId + '"]');
			if (!sourceListEl || !targetListEl) return;

			Array.from(sourceListEl.querySelectorAll('[data-article-id]'))
				.forEach(function (el, i) {
					items.push({ id: parseInt(el.dataset.articleId, 10), sort_order: i, article_group_id: sourceGid });
				});

			Array.from(targetListEl.querySelectorAll('[data-article-id]'))
				.forEach(function (el, i) {
					items.push({ id: parseInt(el.dataset.articleId, 10), sort_order: i, article_group_id: targetGid });
				});
		}

		if (items.length > 0) {
			hook.putJson(apiUrl + '/articles/reorder', { items: items }).then(function () {
				hook.showToast(hook.lang('saved'));
				hook.refreshData();
			}).catch(function (err) {
				hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
				hook.refreshData();
			});
		}
	}

	// Initialize on first render and re-initialize on each re-render
	document.addEventListener('hospitality:articles-rendered', initSortables);

	// If articles were already rendered before this module loaded (race condition),
	// initialize immediately
	if (hook.root && hook.root.querySelector('[data-dnd-article-list]')) {
		initSortables();
	}
})();
</script>
{% endif %}
