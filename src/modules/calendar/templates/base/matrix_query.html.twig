{# Matrix_query template #}
<!-- $Id$ -->
{% block matrix_query %}
<center>
<form action="{{ action_url | raw }}" method="post" name="matrixform">
<table border="0" width="90%">
 <tr class="th">\n        <td colspan="2">&nbsp;<b>{{ lang('{{ title }}') }}</b></td>\n    </tr>\n\n    {# {{ title }} section #}
 {{ rows|raw }}
 <tr>
  <td>
   <table cellspacing="5"><tr>
    <td><input type="submit" value="{{ submit_button }}"></form></td>
    <td>{{ cancel_button }}</td>
   </tr></table>
  </td>
 </tr>
</table>
</center>
{% endblock %}
{% block list %}
 <tr class="{{ tr_color }}">
  <td valign="top" width="35%"><b>&nbsp;{{ field }}:</b></td>
  <td valign="top" width="65%">{{ data }}</td>
 </tr>
{% endblock %}
