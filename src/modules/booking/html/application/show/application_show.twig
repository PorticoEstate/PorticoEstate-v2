	 data-lang-application-accepted="{{ lang('booking.application_accepted') }}"
	 data-lang-application-rejected="{{ lang('booking.application_rejected') }}"
	 data-lang-case-officer-changed="{{ lang('booking.case_officer_changed') }}"
	 data-lang-cost="{{ lang('booking.cost') }}"
	 data-lang-delete="{{ lang('common.delete') }}"
	 data-lang-subject="{{ lang('booking.subject') }}"
	 data-lang-message="{{ lang('booking.message') }}"
	 data-lang-message-sent="{{ lang('booking.message_sent') }}"
	 data-lang-modified="{{ lang('booking.modified') }}"
	 data-lang-archive-key="{{ lang('booking.archive_key') }}"
	 data-lang-in-tax-register="{{ lang('booking.in_tax_register') }}"
	 data-lang-unit="{{ lang('booking.unit') }}"
	 data-lang-unit-price="{{ lang('booking.unit_cost') }}"
>
	{# Loading state — replaced by JS once data arrives #}
	<div id="application-loading" class="app-show__loading">
		<div class="app-show__spinner"></div>
		<p>{{ lang('common.loading') }}...</p>
	</div>

	{# Error state — shown by JS on fetch failure #}
	<div id="application-error" class="app-show__error" hidden>
		<p id="application-error-message"></p>
	</div>

	{# Content — populated by JS #}
	<div id="application-content" hidden>
		{# Toolbar — rendered by JS with dropdown buttons #}
		<div id="application-toolbar" class="app-show__toolbar-container"></div>

		{# Header #}
		<div id="application-header" class="app-show__header"></div>

		{# Tab navigation #}
		<div class="app-show__tabs" role="tablist">
			<button class="app-show__tab app-show__tab--active" role="tab" aria-selected="true" data-tab="details">
				{{ lang('booking.details') }}
			</button>
			<button class="app-show__tab" role="tab" aria-selected="false" data-tab="notes">
				{{ lang('booking.internal_notes') }}
			</button>
			<button class="app-show__tab" role="tab" aria-selected="false" data-tab="history">
				{{ lang('booking.history') }}
			</button>
			<button class="app-show__tab" role="tab" aria-selected="false" data-tab="terms">
				{{ lang('booking.terms and conditions') }}
			</button>
		</div>

		{# Tab: Details #}
		<div id="tab-details" class="app-show__tab-content" role="tabpanel">
			<div id="application-details"></div>
		</div>

		{# Tab: Internal Notes #}
		<div id="tab-notes" class="app-show__tab-content" role="tabpanel" hidden>
			<div id="application-notes"></div>
		</div>

		{# Tab: History / Comments #}
		<div id="tab-history" class="app-show__tab-content" role="tabpanel" hidden>
			<div id="application-comments"></div>
		</div>

		{# Tab: Terms and Conditions #}
		<div id="tab-terms" class="app-show__tab-content" role="tabpanel" hidden>
			<div id="application-terms"></div>
		</div>
	</div>
</div>
