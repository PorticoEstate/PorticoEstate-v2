<script>
(function initHospCollab() {
	var hook = window.__hospWs;
	if (!hook) return;

	var root = hook.root;
	var accountId = root.dataset.accountId;
	var accountName = root.dataset.accountName;
	if (!accountId) return;

	var collab = new CollabClient({
		entityType: 'hospitality',
		entityId: root.dataset.hospitalityId,
		userName: accountName,
		userId: accountId
	});

	// Wire callbacks
	collab.onPresenceChange(function (peers) {
		hook.renderPresence(peers);
	});

	collab.onEditIndicator(function (info) {
		if (info.editing) {
			hook.showEditIndicator(info.peerId, info.userName, info.scope);
		} else {
			hook.removeEditIndicator(info.peerId, info.scope);
		}
	});

	collab.onEntityUpdate(function (update) {
		if (update.section === '_deleted') {
			hook.showDeletedBanner();
			return;
		}
		// Always refresh — server broadcasts arrive for all tabs including
		// the one that triggered the save. The saving tab already has fresh
		// data from its PUT response, so a redundant fetch is harmless.
		hook.refreshSection(update.section);
	});

	collab.onConnectionChange(function (connected) {
		hook.showConnectionStatus(connected);
	});

	// Expose for inline editing integration
	hook.collab = collab;
	collab.connect();
})();
</script>
{% if can_write %}
<script type="module">
import { DragDropManager, Droppable } from '@dnd-kit/dom';
import { Sortable, isSortable, SortableKeyboardPlugin, OptimisticSortingPlugin } from '@dnd-kit/dom/sortable';

(function initHospDnd() {
	var hook = window.__hospDnd;
	if (!hook) return;

	var manager = new DragDropManager();
	var sortables = [];
	var droppables = [];

	function destroyAll() {
		sortables.forEach(function (s) { s.destroy(); });
		sortables = [];
		droppables.forEach(function (d) { d.destroy(); });
		droppables = [];
	}

	function initSortables() {
		destroyAll();

		var root = hook.root;
		if (!root) return;

		// --- Group sortables ---
		var groupEls = root.querySelectorAll('[data-group-id][data-group-index]');
		groupEls.forEach(function (el) {
			var groupId = el.dataset.groupId;
			var index = parseInt(el.dataset.groupIndex, 10);
			var handle = el.querySelector('[data-drag-handle-group="' + groupId + '"]');

			var s = new Sortable(
				{
					id: 'group-' + groupId,
					index: index,
					group: 'groups',
					type: 'group',
					accept: 'group',
					element: el,
					handle: handle || undefined,
					feedback: 'default',
					plugins: [SortableKeyboardPlugin],
					data: { type: 'group', groupId: groupId }
				},
				manager
			);
			sortables.push(s);
		});

		// --- Article sortables + group container droppables ---
		var articleLists = root.querySelectorAll('[data-dnd-article-list]');
		articleLists.forEach(function (listEl) {
			var listGroupId = listEl.dataset.dndArticleList;

			// Create a Droppable for each container (groups + ungrouped)
			var d = new Droppable(
				{
					id: 'container-' + listGroupId,
					element: listEl,
					collisionPriority: 0, // Lowest — Sortable items take precedence
					accept: function (draggable) {
						return draggable.data && draggable.data.type === 'article';
					},
					data: { type: 'article-container', groupId: listGroupId }
				},
				manager
			);
			droppables.push(d);

			var articleEls = listEl.querySelectorAll('[data-article-id]');
			articleEls.forEach(function (el) {
				var articleId = el.dataset.articleId;
				var index = parseInt(el.dataset.articleIndex, 10);
				var handle = el.querySelector('[data-drag-handle-article="' + articleId + '"]');

				var s = new Sortable(
					{
						id: 'article-' + articleId,
						index: index,
						group: 'articles-' + listGroupId,
						type: 'article',
						accept: 'article',
						element: el,
						handle: handle || undefined,
						feedback: 'default',
						plugins: [SortableKeyboardPlugin, OptimisticSortingPlugin],
						data: { type: 'article', articleId: articleId, groupId: listGroupId }
					},
					manager
				);
				sortables.push(s);
			});
		});
	}

	// Collab: notify peers about drag start
	manager.monitor.addEventListener('dragstart', function () {
		if (window.__hospWs && window.__hospWs.collab) {
			window.__hospWs.collab.startEditing('drag:articles');
		}
	});

	// Track the last foreign-group target during drag (for cross-group drops)
	var _lastForeignTarget = null;
	var _lastDragoverLog = '';
	manager.monitor.addEventListener('dragover', function (event) {
		var target = event.operation.target;
		var source = event.operation.source;

		// Remove all active highlights
		document.querySelectorAll('.hosp-show__drop-active').forEach(function (el) {
			el.classList.remove('hosp-show__drop-active');
		});

		// Track foreign-group article targets for cross-group detection
		if (target && target.data && source && isSortable(source)) {
			var sourceGroupId = source.sortable.draggable.data.groupId;
			var targetData = target.data;

			if (targetData.type === 'article' && String(targetData.groupId) !== String(sourceGroupId)) {
				_lastForeignTarget = { groupId: targetData.groupId, articleId: targetData.articleId };
			} else if (targetData.type === 'article-container' && String(targetData.groupId) !== String(sourceGroupId)) {
				_lastForeignTarget = { groupId: targetData.groupId, articleId: null };
				if (target.element) target.element.classList.add('hosp-show__drop-active');
			}
		}

		// Highlight container if target is a container droppable
		if (target && target.data && target.data.type === 'article-container') {
			if (target.element) target.element.classList.add('hosp-show__drop-active');
		}

		// Debug: log target changes
		var logKey = target ? (target.data ? JSON.stringify(target.data) : target.id) : 'none';
		if (logKey !== _lastDragoverLog) {
			_lastDragoverLog = logKey;
			if (COLLAB_DEBUG) console.log('[DnD] dragover target:', target ? target.data : null, 'isSortable:', target ? isSortable(target) : false);
		}
	});

	// Listen for dragend events
	manager.monitor.addEventListener('dragend', function (event) {
		// Collab: notify peers about drag end
		if (window.__hospWs && window.__hospWs.collab) {
			window.__hospWs.collab.stopEditing('drag:articles');
		}

		// Clean up highlights
		document.querySelectorAll('.hosp-show__drop-active').forEach(function (el) {
			el.classList.remove('hosp-show__drop-active');
		});

		var source = event.operation.source;
		var target = event.operation.target;
		var foreignTarget = _lastForeignTarget;
		_lastForeignTarget = null; // Reset for next drag

		if (COLLAB_DEBUG) console.log('[DnD] dragend', {
			sourceData: source && isSortable(source) ? source.sortable.draggable.data : null,
			targetData: target ? target.data : null,
			foreignTarget: foreignTarget
		});

		if (!source) return;

		// Case 1: Sortable-to-sortable (within/between groups with items)
		if (isSortable(source)) {
			var sortable = source.sortable;
			var data = sortable.draggable.data;

			if (data.type === 'group') {
				handleGroupReorder(sortable, target);
				return;
			}

			if (data.type === 'article') {
				// Cross-group detection must run BEFORE DOM-based reorder,
				// because @dnd-kit may leave a ghost/clone element in the
				// source container that causes handleArticleReorder to
				// misdetect a same-group change.
				var crossGroupId = null;
				var crossNearId = null;

				if (foreignTarget && String(foreignTarget.groupId) !== String(data.groupId)) {
					crossGroupId = foreignTarget.groupId;
					crossNearId = foreignTarget.articleId;
				} else if (target && target.data && target.data.type === 'article-container'
					&& String(target.data.groupId) !== String(data.groupId)) {
					crossGroupId = target.data.groupId;
				}

				if (crossGroupId !== null) {
					if (COLLAB_DEBUG) console.log('[DnD] cross-group drop', { crossGroupId: crossGroupId, crossNearId: crossNearId });
					handleArticleDropOnContainer(data.articleId, crossGroupId, crossNearId);
					return;
				}

				// Same-group reorder via DOM scan
				if (handleArticleReorder(sortable, target)) return;
			}
		}
	});

	function handleGroupReorder(sourceSortable, target) {
		// Read DOM order of groups after optimistic sort
		var root = hook.root;
		var apiUrl = hook.getApiUrl();
		var data = hook.getData();
		var groups = data.article_groups || [];

		var domGroupIds = Array.from(root.querySelectorAll('[data-group-id][data-group-index]'))
			.map(function (el) { return el.dataset.groupId; });

		var dataGroupIds = groups
			.sort(function (a, b) { return (a.sort_order || 0) - (b.sort_order || 0); })
			.map(function (g) { return String(g.id); });

		var changed = domGroupIds.length !== dataGroupIds.length
			|| domGroupIds.some(function (id, i) { return id !== dataGroupIds[i]; });

		if (!changed) return;

		var promises = [];
		domGroupIds.forEach(function (groupId, newIndex) {
			var original = groups.find(function (g) { return String(g.id) === String(groupId); });
			if (original && original.sort_order !== newIndex) {
				promises.push(hook.putJson(apiUrl + '/article-groups/' + groupId, { sort_order: newIndex }));
			}
		});

		if (promises.length > 0) {
			Promise.all(promises).then(function () {
				hook.showToast(hook.lang('saved'));
				hook.refreshData();
			}).catch(function (err) {
				hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
				hook.refreshData();
			});
		}
	}

	function handleArticleDropOnContainer(articleId, targetGroupId, nearArticleId) {
		var apiUrl = hook.getApiUrl();
		var newGroupId = targetGroupId === 'ungrouped' ? null : parseInt(targetGroupId, 10);
		var sourceArticleId = String(articleId);

		var data = hook.getData();
		var allArticles = data.articles || [];

		// Get current articles in target group, sorted
		var targetArticles = allArticles
			.filter(function (a) {
				var gid = a.article_group_id != null ? String(a.article_group_id) : null;
				return gid === (newGroupId != null ? String(newGroupId) : null);
			})
			.sort(function (a, b) { return (a.sort_order || 0) - (b.sort_order || 0); });

		var targetIds = targetArticles.map(function (a) { return String(a.id); });

		// Determine insert position
		if (nearArticleId) {
			var nearIdx = targetIds.indexOf(String(nearArticleId));
			if (nearIdx !== -1) {
				// Insert after the near article
				targetIds.splice(nearIdx + 1, 0, sourceArticleId);
			} else {
				targetIds.push(sourceArticleId);
			}
		} else {
			// No specific position — append at end
			targetIds.push(sourceArticleId);
		}

		// Build reorder items for target group
		var items = [];
		targetIds.forEach(function (aid, i) {
			items.push({ id: parseInt(aid, 10), sort_order: i, article_group_id: newGroupId });
		});

		// Also reindex the source group (remove the moved article)
		var movedArticle = allArticles.find(function (a) { return String(a.id) === sourceArticleId; });
		if (movedArticle) {
			var sourceGid = movedArticle.article_group_id != null ? movedArticle.article_group_id : null;
			if (String(sourceGid) !== String(newGroupId)) {
				var sourceArticles = allArticles
					.filter(function (a) {
						var gid = a.article_group_id != null ? String(a.article_group_id) : null;
						return gid === (sourceGid != null ? String(sourceGid) : null)
							&& String(a.id) !== sourceArticleId;
					})
					.sort(function (a, b) { return (a.sort_order || 0) - (b.sort_order || 0); });

				sourceArticles.forEach(function (a, i) {
					items.push({ id: a.id, sort_order: i, article_group_id: sourceGid });
				});
			}
		}

		hook.putJson(apiUrl + '/articles/reorder', { items: items }).then(function () {
			hook.showToast(hook.lang('saved'));
			hook.refreshData();
		}).catch(function (err) {
			hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
			hook.refreshData();
		});
	}

	function handleArticleReorder(sourceSortable, target) {
		var apiUrl = hook.getApiUrl();
		var root = hook.root;
		var data = hook.getData();
		var allArticles = data.articles || [];

		function parseGroupId(gid) {
			if (!gid || gid === 'ungrouped') return null;
			return parseInt(gid, 10);
		}

		// Scan ALL article list containers and compare DOM order to data.
		// The optimistic plugin may have moved elements within or across containers.
		var items = [];
		var changed = false;
		var articleLists = root.querySelectorAll('[data-dnd-article-list]');

		articleLists.forEach(function (listEl) {
			var gid = parseGroupId(listEl.dataset.dndArticleList);
			var domIds = Array.from(listEl.querySelectorAll('[data-article-id]'))
				.map(function (el) { return el.dataset.articleId; });

			// Compare to data: articles that belong to this group, sorted
			var dataIds = allArticles
				.filter(function (a) {
					var aGid = a.article_group_id != null ? a.article_group_id : null;
					return String(aGid || '') === String(gid || '');
				})
				.sort(function (a, b) { return (a.sort_order || 0) - (b.sort_order || 0); })
				.map(function (a) { return String(a.id); });

			var listChanged = domIds.length !== dataIds.length
				|| domIds.some(function (id, i) { return id !== dataIds[i]; });

			if (listChanged) changed = true;

			domIds.forEach(function (aid, i) {
				items.push({ id: parseInt(aid, 10), sort_order: i, article_group_id: gid });
			});
		});

		if (!changed) return false;

		hook.putJson(apiUrl + '/articles/reorder', { items: items }).then(function () {
			hook.showToast(hook.lang('saved'));
			hook.refreshData();
		}).catch(function (err) {
			hook.showToast(hook.lang('error') + ': ' + err.message, 'danger');
			hook.refreshData();
		});
		return true;
	}

	// Initialize on first render and re-initialize on each re-render
	document.addEventListener('hospitality:articles-rendered', initSortables);

	// If articles were already rendered before this module loaded (race condition),
	// initialize immediately
	if (hook.root && hook.root.querySelector('[data-dnd-article-list]')) {
		initSortables();
	}
})();
</script>
{% endif %}
{% endblock %}
