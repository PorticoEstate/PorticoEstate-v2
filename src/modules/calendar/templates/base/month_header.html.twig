{# Month_header template #}
<!-- $Id$ -->
{% block monthly_header %}
 <tr colspan="{{ cols }}" width="{{ col_width }}%">
{{ column_header }}</tr>
{% endblock %}
{% block column_title %}
  <th width="11%" class="th"><font color="{{ font_color }}">{{ col_title }}</font></th>
{% endblock %}
{% block month_column %}
  <td valign="top" height="75" colspan="1" width="{{ col_width }}%"{{ extra }}>
{{ column_data }}
  </td>
{% endblock %}

